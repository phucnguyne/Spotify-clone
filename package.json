{
  "name": "spotify-clone",
  "private": true,
  "scripts": {
    "dev":        "pnpm run --parallel dev:fe dev:be",
    "dev:fe":     "pnpm --filter frontend dev",
    "dev:be":     "pnpm --filter backend dev",
    "build":      "pnpm --filter frontend build",
    "lint":       "pnpm -r lint",
    "test":       "pnpm -r test",
    "install:all": "pnpm install"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}